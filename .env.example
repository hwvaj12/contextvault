# ContextVault Configuration
PORT=3000
CONTEXTVAULT_API_KEY=cv-test-api-key-123
CONTEXTVAULT_DATA_DIR=./data

# Secrets Configuration (Phase 13)
# Backend: local | doppler | aws | gcp (default: local)
CONTEXTVAULT_SECRETS_BACKEND=local
CONTEXTVAULT_SECRETS_PATH=./data/secrets

# Signing Keys (for workspace bundles)
# CONTEXTVAULT_SIGNING_PRIVATE_KEY=base64_encoded_private_key
# CONTEXTVAULT_SIGNING_PUBLIC_KEY=base64_encoded_public_key
# CONTEXTVAULT_SIGNING_KEY_ID=v1

# Tenant Master Key (for SQLCipher encryption - future)
# CONTEXTVAULT_TENANT_KEY=base64_encoded_256bit_key
