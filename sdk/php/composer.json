{
    "name": "contextvault/contextvault-php",
    "description": "Official PHP SDK for ContextVault - versioned context storage for AI agents",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0"
    },
    "autoload": {
        "psr-4": {
            "ContextVault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContextVault\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
